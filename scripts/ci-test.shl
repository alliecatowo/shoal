#!/usr/bin/env shoal
# Build and test the entire workspace through the shipped CLI.

let locks = (reef lock)
let cargo_lock = locks.find(.name == "cargo")
assert(cargo_lock != null && cargo_lock.locked, "CI could not lock cargo through Reef: {locks}")
run("cargo", "build", "--workspace", "--all-targets", "--locked")
run("scripts/help-audit.shl")
run("cargo", "test", "--workspace", "--locked")
run("cargo", "test", "-p", "shoal", "--test", "conformance", "--locked", "--", "--nocapture")
echo "workspace test gate passed"
