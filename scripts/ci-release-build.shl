#!/usr/bin/env shoal
# Prove the optimized workspace builds on the current host.

let locks = (reef lock)
let cargo_lock = locks.find(.name == "cargo")
assert(cargo_lock != null && cargo_lock.locked, "CI could not lock cargo through Reef: {locks}")
run("cargo", "build", "--workspace", "--release", "--locked")
echo "release workspace build passed"
