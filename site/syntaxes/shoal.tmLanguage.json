{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "shoal",
  "displayName": "Shoal",
  "scopeName": "source.shoal",
  "fileTypes": ["shoal", "shl"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#tagged-literals" },
    { "include": "#strings" },
    { "include": "#declarations" },
    { "include": "#keywords" },
    { "include": "#constants" },
    { "include": "#types" },
    { "include": "#time-literals" },
    { "include": "#unit-numbers" },
    { "include": "#numbers" },
    { "include": "#flags" },
    { "include": "#paths-and-globs" },
    { "include": "#namespaces" },
    { "include": "#members-and-calls" },
    { "include": "#operators" },
    { "include": "#punctuation" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.shoal",
          "match": "(?<!\\S)#.*$"
        }
      ]
    },
    "tagged-literals": {
      "patterns": [
        {
          "name": "string.regexp.shoal",
          "begin": "\\b(re)(\")",
          "beginCaptures": {
            "1": { "name": "storage.type.regexp.shoal" },
            "2": { "name": "punctuation.definition.string.begin.shoal" }
          },
          "end": "\"",
          "endCaptures": {
            "0": { "name": "punctuation.definition.string.end.shoal" }
          },
          "patterns": [
            { "name": "constant.character.escape.regexp.shoal", "match": "\\\\." },
            { "name": "keyword.operator.quantifier.regexp.shoal", "match": "[?+*]|\\{[0-9]+(?:,[0-9]*)?\\}" },
            { "name": "keyword.operator.or.regexp.shoal", "match": "\\|" },
            { "name": "constant.other.character-class.regexp.shoal", "match": "\\[(?:\\\\.|[^\\]])*\\]" }
          ]
        },
        {
          "name": "string.quoted.double.datetime.shoal",
          "begin": "\\b(t)(\")",
          "beginCaptures": {
            "1": { "name": "storage.type.datetime.shoal" },
            "2": { "name": "punctuation.definition.string.begin.shoal" }
          },
          "end": "\"",
          "endCaptures": {
            "0": { "name": "punctuation.definition.string.end.shoal" }
          }
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.triple.raw.shoal",
          "begin": "'''",
          "beginCaptures": { "0": { "name": "punctuation.definition.string.begin.shoal" } },
          "end": "'''",
          "endCaptures": { "0": { "name": "punctuation.definition.string.end.shoal" } }
        },
        {
          "name": "string.quoted.triple.double.shoal",
          "begin": "\"\"\"",
          "beginCaptures": { "0": { "name": "punctuation.definition.string.begin.shoal" } },
          "end": "\"\"\"",
          "endCaptures": { "0": { "name": "punctuation.definition.string.end.shoal" } },
          "patterns": [
            { "include": "#escapes" },
            { "include": "#interpolation" }
          ]
        },
        {
          "name": "string.quoted.single.raw.shoal",
          "begin": "'",
          "beginCaptures": { "0": { "name": "punctuation.definition.string.begin.shoal" } },
          "end": "'",
          "endCaptures": { "0": { "name": "punctuation.definition.string.end.shoal" } }
        },
        {
          "name": "string.quoted.double.shoal",
          "begin": "\"",
          "beginCaptures": { "0": { "name": "punctuation.definition.string.begin.shoal" } },
          "end": "\"",
          "endCaptures": { "0": { "name": "punctuation.definition.string.end.shoal" } },
          "patterns": [
            { "include": "#escapes" },
            { "include": "#interpolation" }
          ]
        }
      ]
    },
    "escapes": {
      "patterns": [
        {
          "name": "constant.character.escape.shoal",
          "match": "\\\\(?:[ntr0\\\\\"'{}]|u\\{[0-9A-Fa-f]{1,6}\\})"
        }
      ]
    },
    "interpolation": {
      "patterns": [
        {
          "name": "meta.interpolation.shoal",
          "begin": "(?<!\\\\)\\{",
          "beginCaptures": { "0": { "name": "punctuation.section.interpolation.begin.shoal" } },
          "end": "\\}",
          "endCaptures": { "0": { "name": "punctuation.section.interpolation.end.shoal" } },
          "patterns": [ { "include": "$self" } ]
        }
      ]
    },
    "declarations": {
      "patterns": [
        {
          "match": "\\b(fn)(\\s+)([A-Za-z_][A-Za-z0-9_-]*)",
          "captures": {
            "1": { "name": "storage.type.function.shoal" },
            "3": { "name": "entity.name.function.shoal" }
          }
        },
        {
          "match": "\\b(let|var|alias|use|export)(\\s+)([A-Za-z_][A-Za-z0-9_-]*)",
          "captures": {
            "1": { "name": "storage.type.binding.shoal" },
            "3": { "name": "variable.other.definition.shoal" }
          }
        },
        {
          "match": "\\b(for)(\\s+)([A-Za-z_][A-Za-z0-9_-]*)(\\s+)(in)\\b",
          "captures": {
            "1": { "name": "keyword.control.loop.shoal" },
            "3": { "name": "variable.other.definition.shoal" },
            "5": { "name": "keyword.control.loop.shoal" }
          }
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.shoal",
          "match": "\\b(?:if|else|match|for|in|while|try|catch|with|spawn|return|break|continue|throw|assert|select|on)\\b"
        },
        {
          "name": "storage.type.declaration.shoal",
          "match": "\\b(?:let|var|fn|alias|use|export)\\b"
        },
        {
          "name": "keyword.other.stream.shoal",
          "match": "\\b(?:stream|channel|emit|every|watch|tail|feed|run|sh)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        { "name": "constant.language.boolean.shoal", "match": "\\b(?:true|false)\\b" },
        { "name": "constant.language.null.shoal", "match": "\\bnull\\b" },
        { "name": "variable.language.shoal", "match": "\\b(?:it|out|env|args|now|today)\\b" }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.shoal",
          "match": "\\b(?:any|bool|bytes|datetime|duration|error|float|glob|int|list|null|outcome|path|record|regex|secret|size|str|stream|table|task|time)\\b"
        }
      ]
    },
    "time-literals": {
      "patterns": [
        {
          "name": "constant.numeric.time.shoal",
          "match": "\\b(?:[01]?[0-9]|2[0-3]):[0-5][0-9](?::[0-5][0-9])?(?:am|pm)?\\b"
        }
      ]
    },
    "unit-numbers": {
      "patterns": [
        {
          "name": "constant.numeric.unit.shoal",
          "match": "(?i)\\b(?:[0-9](?:[0-9_]*[0-9])?(?:\\.[0-9](?:[0-9_]*[0-9])?)?)(?:ns|us|µs|ms|s|m|h|d|w|b|kb|mb|gb|tb|kib|mib|gib|tib)\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        { "name": "constant.numeric.hex.shoal", "match": "\\b0x[0-9A-Fa-f](?:_?[0-9A-Fa-f])*\\b" },
        { "name": "constant.numeric.octal.shoal", "match": "\\b0o[0-7](?:_?[0-7])*\\b" },
        { "name": "constant.numeric.binary.shoal", "match": "\\b0b[01](?:_?[01])*\\b" },
        { "name": "constant.numeric.float.shoal", "match": "\\b[0-9](?:_?[0-9])*(?:\\.[0-9](?:_?[0-9])*)?(?:[eE][+-]?[0-9](?:_?[0-9])*)\\b" },
        { "name": "constant.numeric.float.shoal", "match": "\\b[0-9](?:_?[0-9])*\\.[0-9](?:_?[0-9])*\\b" },
        { "name": "constant.numeric.integer.shoal", "match": "\\b[0-9](?:_?[0-9])*\\b" }
      ]
    },
    "flags": {
      "patterns": [
        {
          "name": "constant.other.option.shoal",
          "match": "(?<![A-Za-z0-9_-])--?[A-Za-z][A-Za-z0-9_-]*(?:=[^\\s,;]+)?"
        }
      ]
    },
    "paths-and-globs": {
      "patterns": [
        {
          "name": "string.unquoted.path.shoal",
          "match": "(?<![A-Za-z0-9_])(?:~/|/|\\./|\\.\\./)[^\\s,;\\]\\[(){}]+"
        },
        {
          "name": "string.unquoted.glob.shoal",
          "match": "(?<!\\S)[^\\s,;]*[*?][^\\s,;]*"
        }
      ]
    },
    "namespaces": {
      "patterns": [
        {
          "name": "support.type.namespace.shoal",
          "match": "\\b(?:bytes|config|csv|datetime|env|fs|glob|http|journal|json|math|os|path|reef|regex|secret|sys|time|toml|yaml)(?=\\.)"
        }
      ]
    },
    "members-and-calls": {
      "patterns": [
        { "name": "entity.name.function.call.shoal", "match": "\\b[A-Za-z_][A-Za-z0-9_-]*(?=\\s*\\()" },
        { "name": "variable.other.member.shoal", "match": "(?<=\\.)[A-Za-z_][A-Za-z0-9_-]*" },
        { "name": "variable.parameter.label.shoal", "match": "\\b[A-Za-z_][A-Za-z0-9_-]*(?=\\s*:)" }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.shoal",
          "match": "\\.\\.=|\\.\\.|\\?\\.|\\?\\?|=>|->|==|!=|<=|>=|&&|\\|\\||\\+=|-=|\\*=|/=|%=|[+*/%<>=!&^|-]"
        },
        { "name": "punctuation.accessor.shoal", "match": "\\." }
      ]
    },
    "punctuation": {
      "patterns": [
        { "name": "punctuation.section.group.shoal", "match": "[()\\[\\]{}]" },
        { "name": "punctuation.separator.shoal", "match": "[,;:]" }
      ]
    }
  }
}
